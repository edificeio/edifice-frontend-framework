{
  "$schema": "node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "test:coverage": {
      "cache": false
    },
    "docs": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build", "lint", "fix"],
      "outputs": []
    },
    "preview": {
      "cache": false
    },
    "fix": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    }
  }
}
