{
  "name": "@edifice.io/impact-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "Cartographie des dependances entre @edifice.io/* et les apps consommatrices (ENABLING-1023)",
  "license": "AGPL-3.0",
  "author": "Edifice",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "generate:local": "tsx --env-file-if-exists=.env src/cli.ts generate --mode=local",
    "generate:ci": "tsx --env-file-if-exists=.env src/cli.ts generate --mode=ci",
    "fix": "eslint --fix --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "postcss": "catalog:",
    "postcss-scss": "catalog:",
    "postcss-selector-parser": "catalog:",
    "ts-morph": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "4.20.6",
    "typescript": "catalog:",
    "vitest": "3.2.4"
  }
}
