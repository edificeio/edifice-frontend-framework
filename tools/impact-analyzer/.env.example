# Mode distant (--mode=ci) — voir README.md "Mode distant"
# Ne jamais committer de vraie valeur ici : ce fichier ne sert qu'à documenter les noms attendus.

# Générique — fallback si un seul classic PAT couvre tout
IMPACT_ANALYZER_GITHUB_TOKEN=

# Spécifique par org — prend le pas sur le générique.
# Nom = org GitHub en UPPER_SNAKE_CASE (tirets -> underscores).
IMPACT_ANALYZER_GITHUB_TOKEN_EDIFICEIO=
IMPACT_ANALYZER_GITHUB_TOKEN_OPEN_ENT_NG=
