{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext"],
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src", "test", "config", "apps.json"],
  "exclude": ["node_modules", "data", "viewer"]
}
